# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (set DB_ENGINE=sqlite to use SQLite instead of PostgreSQL)
DB_ENGINE=postgresql
DB_NAME=medassist
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Azure Form Recognizer (OCR) - leave empty to use mock OCR
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# Gemini API (for intelligent prescription parsing)
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
